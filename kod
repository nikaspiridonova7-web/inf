function renderMessage(msg) {
  if (msg.type === 'image') return `<div class="image-card">${msg.text}</div>`;
  const cls = msg.type === 'card' ? 'bubble card' : msg.type === 'warning' ? 'bubble warning' : 'bubble';
  return `<div class="${cls}">${escapeHtml(msg.text)}</div>`;
}
function renderButtons(buttons) {
  if (!buttons || !buttons.length) return '';
  return `<div class="quick-title">Кнопки бота</div><div class="buttons">${buttons.map(btn => `<button class="tg-btn ${btn.action === 'back' ? 'secondary' : ''}" onclick="handleButton('${btn.action || 'go'}','${btn.target || ''}')">${btn.label}</button>`).join('')}</div>`;
}
function escapeHtml(str) {
  return String(str).replace(/[&<>"]/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[s]));
}
function go(screenId, push = true) {
  if (!screens[screenId]) screenId = 'unknown';
  if (push && currentScreen && currentScreen !== screenId) historyStack.push(currentScreen);
  currentScreen = screenId;
  const screen = screens[screenId];
  const chat = document.getElementById('chat');
  chat.innerHTML = screen.messages.map(renderMessage).join('') + renderButtons(screen.buttons);
  chat.scrollTop = 0;
}
function handleButton(action, target) {
  if (action === 'back') {
    const prev = historyStack.pop() || 'menu';
    currentScreen = prev;
    const screen = screens[prev];
    const chat = document.getElementById('chat');
    chat.innerHTML = screen.messages.map(renderMessage).join('') + renderButtons(screen.buttons);
    return;
  }
  go(target, true);
}
function sendUnknown() {
  const input = document.getElementById('userInput');
  input.value = '';
  go('unknown', true);
}

go('start', false);
